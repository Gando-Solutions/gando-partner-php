{
  "name": "gando/partner",
  "type": "library",
  "autoload": {
    "psr-4": {
      "Gando\\Partner\\": "src/"
    }
  },
  "license": "MIT",
  "require": {
    "php": ">=8.2",
    "brick/date-time": ">=0.7.0",
    "brick/math": ">=0.12.1",
    "galbar/jsonpath": ">=3.0",
    "guzzlehttp/guzzle": "^7.0",
    "php-http/discovery": "^1.20",
    "phpdocumentor/type-resolver": ">=1.8",
    "psr/event-dispatcher": "^1.0",
    "psr/http-client": "^1.0",
    "psr/http-factory": "^1.0",
    "psr/log": "^1.1 || ^2.0 || ^3.0",
    "psr/simple-cache": "^1.0 || ^2.0 || ^3.0",
    "speakeasy/serializer": "^4.0.3"
  },
  "suggest": {
    "guzzlehttp/guzzle": "Required for Speakeasy transport bridge; also used by php-http/discovery when no other PSR-18 client is installed"
  },
  "require-dev": {
    "laravel/pint": "1.29.0",
    "phpstan/phpstan": "2.1.44",
    "phpunit/phpunit": "^11.5.50 || ^12.5.8 || >=13.0.0",
    "rector/rector": "^2.4",
    "roave/security-advisories": "dev-latest"
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "config": {
    "optimize-autoloader": true,
    "classmap-authoritative": true,
    "sort-packages": true,
    "process-timeout": 60,
    "allow-plugins": {
      "php-http/discovery": true
    }
  },
  "scripts": {
    "cs-check": [
      "./vendor/bin/pint --test"
    ],
    "lint": [
      "./vendor/bin/pint"
    ],
    "rector": [
      "./vendor/bin/rector process --ansi",
      "php ./scripts/validate-generated-invariants.php"
    ],
    "test": [
      "./vendor/bin/phpunit --testdox --display-warnings --colors=always"
    ],
    "stan": [
      "./vendor/bin/phpstan analyse --memory-limit=2g --error-format=table"
    ]
  },
  "script-descriptions": {
    "test": "Run PhpUnit test scripts.",
    "stan": "Run PhpStan static analysis."
  }
}
